Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "x"}], ",", 
       RowBox[{"0", "<=", "x", "<", 
        RowBox[{"1", "/", "2"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"2", "x"}], "-", "1"}], ",", 
       RowBox[{
        FractionBox["1", "2"], "<=", "x", "<=", "1"}]}], "}"}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a_", ",", "b_"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"c_", ",", "d_"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"e_", ",", "m_"}], "}"}]}], "}"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"e", ",", "m"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", 
       RowBox[{"f", "[", "m", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"f", "[", "m", "]"}], ",", 
       RowBox[{"f", "[", "m", "]"}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"range", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n", "=", "90"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{
    RowBox[{
     SqrtBox["2"], "-", "1"}], "//", "N"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"NestList", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x0", ",", 
         RowBox[{"f", "[", "x0", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"f", "[", "x0", "]"}], ",", 
         RowBox[{"f", "[", "x0", "]"}]}], "}"}]}], "}"}], ",", "n"}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", "range"}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{"x", ",", "range", ",", 
     RowBox[{"PlotStyle", "->", "Black"}]}], "]"}], ",", 
   RowBox[{"Graphics", "[", 
    RowBox[{"Line", "/@", "data"}], "]"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "0.8"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"Frame", "->", "True"}]}], "]"}]}], "Input",
 CellLabel->
  "In[550]:=",ExpressionUUID->"a8a845a9-ac5b-1b4b-871b-e3edcd6fe919"],

