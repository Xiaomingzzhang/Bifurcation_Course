Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"alpha", "=", 
   RowBox[{"-", "1.2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"beta", "=", "3.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"gamma", "=", "2"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Vector", " ", "Field", " ", "Definition"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"vField", "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "}"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"alpha", "*", "x"}], "-", 
     RowBox[{"beta", "*", "y"}]}], ",", 
    RowBox[{
     RowBox[{"beta", "*", "x"}], "+", 
     RowBox[{"alpha", "*", "y"}]}], ",", 
    RowBox[{"gamma", "*", "z"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"SliceVectorPlot3D", "[", 
    RowBox[{
     RowBox[{"vField", "[", 
      RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", "==", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], ",", 
   RowBox[{"SliceVectorPlot3D", "[", 
    RowBox[{
     RowBox[{"vField", "[", 
      RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}]}], "==", "0.0001"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[222]:=",ExpressionUUID->"c8a97ef2-8487-5a46-82d0-91adb6287b38"],

